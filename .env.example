# exchange or grpc
EXCHANGEBOT_APP_EXCHANGE_TYPE=exchange
# pairs 
EXCHANGEBOT_APP_PAIRS_FROM_FILE=true

#WEB
EXCHANGEBOT_WEB_LISTEN_PORT=80
EXCHANGEBOT_WEB_HOST=
EXCHANGEBOT_WEB_USE_TLS=false
EXCHANGEBOT_WEB_CONTENT_EMBED=
EXCHANGEBOT_WEB_USERNAME_AUTH=
EXCHANGEBOT_WEB_PASSWORD_AUTH=

#EXCHANGE
EXCHANGEBOT_EXCHANGE_API_KEY=
EXCHANGEBOT_EXCHANGE_SECRET_KEY=

#TELEGRAM
EXCHANGEBOT_TLG_TOKEN=
EXCHANGEBOT_TLG_USER=
EXCHANGEBOT_TLG_NOTIFICATION_ENABLE=true
EXCHANGEBOT_TLG_Enable=true

# DB
EXCHANGEBOT_DB_HOST_DOCKER=mysql
EXCHANGEBOT_DB_HOST_LOCAL=127.0.0.1
EXCHANGEBOT_DB_PORT=3306
EXCHANGEBOT_DB_PORT_HOST=
EXCHANGEBOT_DB_USER=
EXCHANGEBOT_DB_PASSWORD=
EXCHANGEBOT_DB_NAME=

#log 
EXCHANGEBOT_LOG_PRODUCTION=false
EXCHANGEBOT_LOG_DEBUG=false

#grpc
EXCHANGEBOT_GRPC_HOST_DOCKER=exchange_service
EXCHANGEBOT_GRPC_HOST_LOCAL=0.0.0.0
EXCHANGEBOT_GRPC_PORT=50051

#tracer
EXCHANGEBOT_OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
EXCHANGEBOT_OTEL_SERVICE_NAME=exchange-bot

#notfication
EXCHANGEBOT_NOTIFICATION_ENABLE=true

#frontend
VITE_GRAFANA_URL=grafana

